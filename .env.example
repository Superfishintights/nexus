# Nexus project-local environment (.env)
#
# Nexus supports config via process environment variables and/or a `.env` file.
# When running `python nexus/server.py` with `cwd` set to the repo root, `./.env`
# is the highest-precedence `.env` location.
#
# Keep a private `.env` locally (ignored by git) and use this file as a template.

# Optional: tool package scanning (comma-separated). Defaults to `tools`.
NEXUS_TOOL_PACKAGES=tools

# Optional: force an explicit env file path (overrides Nexus' normal search).
# NEXUS_ENV_FILE=/absolute/path/to/.env

# ---- Built-in toolsets ----

# Jira
# JIRA_HOSTNAME=your-company.atlassian.net
# JIRA_PAT=your_pat_here

# n8n
# N8N_HOST=https://n8n.example.com
# N8N_API_KEY=your_api_key_here

# Sonarr
# SONARR_URL=http://sonarr.local:8989
# SONARR_API_KEY=your_api_key_here

# Radarr
# RADARR_URL=http://radarr.local:7878
# RADARR_API_KEY=your_api_key_here

# Tautulli
# TAUTULLI_URL=http://tautulli.local:8181
# TAUTULLI_API_KEY=your_api_key_here
