# Nexus project-local environment (.env)
#
# Nexus supports config via process environment variables and/or a `.env` file.
# When running `python nexus/server.py` with `cwd` set to the repo root, `./.env`
# is the highest-precedence `.env` location.
#
# Keep a private `.env` locally (ignored by git) and use this file as a template.

# Optional: tool package scanning (comma-separated).
# Uncomment and list only the pack roots you want to enable.
# NEXUS_TOOL_PACKAGES=nexus_tools_jira,nexus_tools_n8n,nexus_tools_agent_memory
#
# For local monorepo development, you can enable all first-party packs:
# NEXUS_TOOL_PACKAGES=nexus_tools_jira,nexus_tools_n8n,nexus_tools_sonarr,nexus_tools_radarr,nexus_tools_tautulli,nexus_tools_starling,nexus_tools_agent_memory

# Optional: force an explicit env file path (overrides Nexus' normal search).
# NEXUS_ENV_FILE=/absolute/path/to/.env

# ---- Built-in toolsets ----

# Jira
# JIRA_HOSTNAME=your-company.atlassian.net
# JIRA_PAT=your_pat_here

# n8n
# N8N_HOST=https://n8n.example.com
# N8N_API_KEY=your_api_key_here

# Sonarr
# SONARR_URL=http://sonarr.local:8989
# SONARR_API_KEY=your_api_key_here

# Radarr
# RADARR_URL=http://radarr.local:7878
# RADARR_API_KEY=your_api_key_here

# Tautulli
# TAUTULLI_URL=http://tautulli.local:8181
# TAUTULLI_API_KEY=your_api_key_here

# Starling
# STARLING_ENV=production
# STARLING_API_BASE_URL=https://api.starlingbank.com
# Optional legacy single-token fallback:
# STARLING_ACCESS_TOKEN=your_access_token_here
# Preferred split-token setup:
# STARLING_TOKEN_READ_EDIT=your_read_edit_token_here
# STARLING_TOKEN_PAYEE_SAVINGS_CREATE=your_payee_and_savings_create_token_here
# STARLING_TOKEN_PAYMENT_INITIATION=your_payment_initiation_token_here

# Agent memory
# AGENT_MEMORY_BASE_URL=http://192.168.1.238:8787
# AGENT_MEMORY_TOKEN=your_bearer_token_here
# AGENT_MEMORY_DEFAULT_PROFILE=jay/global
# AGENT_MEMORY_AGENT_ID=nexus
# AGENT_MEMORY_TIMEOUT_S=30
